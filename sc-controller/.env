base_dir="$(readlink -f "$(dirname "$0")")"
. "${base_dir}/../bin/package-support.sh"

app_name=sc-controller
repo="git-developer/${app_name}"
base_distro=lunar
fallback_version="0.4.8.11-8-${base_distro}"
log_file="/userdata/system/logs/${app_name}.log"
pid_file=/userdata/system/.config/scc/daemon.pid
profile="${base_dir}/profiles/active.sccprofile"

find_url() {
  find_latest_github_release "${repo}" "${app_name}-" "-${base_distro}-$(uname -m).AppImage" | grep . \
  || echo "https://github.com/${repo}/releases/download/v${fallback_version}/${app_name}-v${fallback_version}-$(uname -m).AppImage"
}
